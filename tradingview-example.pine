//@version=5
indicator("ChatGPT Webhook Example", overlay=true)

fast = ta.ema(close, 9)
slow = ta.ema(close, 21)
longSignal = ta.crossover(fast, slow)
shortSignal = ta.crossunder(fast, slow)

plot(fast, color=color.teal)
plot(slow, color=color.orange)

if longSignal
    alert('{"symbol":"{{ticker}}","exchange":"{{exchange}}","interval":"{{interval}}","price":"{{close}}","time":"{{time}}","signal":"EMA 9 crossed above EMA 21"}', alert.freq_once_per_bar_close)

if shortSignal
    alert('{"symbol":"{{ticker}}","exchange":"{{exchange}}","interval":"{{interval}}","price":"{{close}}","time":"{{time}}","signal":"EMA 9 crossed below EMA 21"}', alert.freq_once_per_bar_close)
